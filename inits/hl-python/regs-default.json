{
    "\\bTB\\] ": "CIBlue",
    "\\b(AA|BB|TT)\\b" : "gray",
    "\\b(EE|FF)\\b": "err",
    "\\bII\\b": "ok",
    "\\bIMP\\b": "imp",
    "# {{{$|# }}}$": "gray",
    "\\b([a-fA-F0-9]{32}|[a-fA-F0-9]{40}|[a-fA-F0-9]{64})\\b": {
      "name": "hash",
      "color": "green",
      "embedded": false,
      "case-match": true
    },
    "\\b(Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec) [0-9]{1,2} [0-9]{2}:[0-9]{2}:[0-9]{2}\\b": {
      "name": "time5",
      "color": "ts",
      "embedded": false,
      "case-match": true
    },
    "\\b(([0-9]{6,}-)?[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]{3,})?)\\b": {
      "name": "time1",
      "color": "ts",
      "embedded": false,
      "case-match": true
    },
    "\\b([0-9]{8}-[0-9]{6}(\\.[0-9]{3,})?)\\b": {
      "name": "time2",
      "color": "ts",
      "embedded": false,
      "case-match": true
    },
    "\\b[0-9]{2,}\\.[0-9]{6}\\b": {
      "name": "time3",
      "color": "ts",
      "embedded": false,
      "case-match": true
    },
    "\\b[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z\\b": {
      "name": "time4",
      "color": "ts",
      "embedded": false,
      "case-match": true
    },
    "\\b([0-9A-Z]{6,}-[A-Z0-9]{5,}-[0-9]{8,}\\]?\\b)": {
      "name": "id",
      "color": "gray",
      "embedded": false,
      "case-match": true
    },
    "\\[[0-9]{4,}\\]:?": {
      "name": "id2",
      "color": "gray",
      "embedded": true,
      "case-match": true
    },
    "\\[?[A-Z]{2,}-[0-9]{3,}\\]?": {
      "name": "ticket-id",
      "color": "ticket",
      "embedded": false,
      "case-match": true
    }
}
