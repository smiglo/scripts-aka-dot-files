#!/usr/bin/env bash

if [[ $1 == '@@' ]]; then # {{{
  case $2 in
  -b)
    for o in $(git remote); do
      git for-each-ref --sort=-committerdate refs/remotes/$o | awk '{print $3}' | sed -e '/HEAD/d' -e 's|refs/remotes/||'
    done;;
  -S)
    git log --format=%h;;
  -s)
    git log --format=%h | head -n 100;;
  *)
    echo "-b -s -S"
    _git_sha_compl --cur "$cur" +branches +remote-branches +tags;;
  esac
  exit 0
fi # }}}

rev="HEAD"
params=
while [[ ! -z $1 ]]; do
  case $1 in
  -s | -S) rev=$2; shift;;
  -b) rev=$2; shift;;
  --) break;;
  -*) params+=" $1";;
  *) [[ ! -e $1 ]] && rev=$1 && shift; break;;
  esac; shift
done
git diff $params $rev~..$rev "$@"
