#!/usr/bin/env bash
# vim: fdl=0

declare -F import-module >/dev/null 2>&1 || source $BASH_PATH/essentials

_screen_lock() { # {{{
  local colors=( 'red' 'green' 'yellow' 'blue' 'magenta' 'cyan' ) tmp=
  local c1="0"
  local c2="$(( ($c1 + 1 + $RANDOM % (${#colors[*]} - 1)) % ${#colors[*]} ))"
  local cmatrix_cmd="nice -n 15 cmatrix -u ${CMATRIX_SPEED:-5} -b"
  import-module mutex-locking time-tools
  local title=
  title="$(tmux show -gv set-titles-string 2>/dev/null)"
  if [[ -n $title ]]; then
    title="${title//\\}"
    [[ "$title" == *" " ]] && title="${title% }" || title="$title " # make a difference to force redraw
    local dummyTitle="$TMUX_TITLE"
    [[ -n $dummyTitle ]] || dummyTitle="$($BASH_PATH/env-ext.sh get get-unicode-char "${TMUX_ICON_HOST:-localhost}")"
    printf "]0;%b%b" "$dummyTitle" "\x07"
  fi
  tput reset
  if ${SSHH_ADD_LOCK_NO_PWD:-false} || [[ -z $SSHH_ADD_LOCK_NO_PWD && -z $SSH_AGENT_LOCK_PWD ]] || [[ "$(tmux display-message -pF '#{client_tty}')" !=  *"/0" && $(tmux list-clients | wc -l) -gt 1 ]] ; then # {{{
    eval $cmatrix_cmd -C ${colors[$(($RANDOM % ${#colors[*]}))]}
    [[ -n $title ]] && tmux set -g set-titles-string "$title"
    return
  fi # }}}
  if [[ ! -z $SSH_AGENT_LOCK_PWD ]]; then # {{{
    local timeout="$SSH_AGENT_LOCK_PRE_TIMEOUT"
    local from_tmux=false
    while [[ ! -z $1 ]]; do
      case $1 in
      --tmux)
        from_tmux=true;
        if [[ ( ! -z $TMUX_SESSION && $(tmux show-option -t $TMUX_SESSION -qv @lock_allowed) == 'false' ) || $(tmux show-option -gqv @lock_allowed) == 'false' ]]; then
          tmux display-message "Locking disabled"
          return 0
        fi;;
      *) timeout="$1";;
      esac
      shift
    done
    mutex-init "ssh-lock" --no-trap --auto-clean-after 0
    if ! mutex-lock; then
      eval $cmatrix_cmd -C ${colors[$c1]}
      [[ -n $title ]] && tmux set -g set-titles-string "$title"
      $from_tmux && tmux display-message "Cannot lock ssh-agent, mutex locked" || echoe "Cannot lock ssh-agent, mutex locked"
      sleep 1
      return 1
    fi
    [[ -z $SSHH_ADD_LOCK_TS_FILE ]] && local SSHH_ADD_LOCK_TS_FILE="$MEM_KEEP/cmatrix.ts"
    local cTime=$EPOCHSECONDS
    local cmatrixLockTime=0 cmatrixLockFileCreated=0
    if [[ $SSHH_ADD_LOCK_TS_FILE != '-' ]]; then
      [[ -e $SSHH_ADD_LOCK_TS_FILE ]] && source $SSHH_ADD_LOCK_TS_FILE
      if [[ $cmatrixLockFileCreated -lt $(date +%s -d "today 0:00") ]]; then
        rm -f $SSHH_ADD_LOCK_TS_FILE
        cmatrixLockTime=0 cmatrixLockFileCreated=$cTime
        $ENV_SCRIPTS/file-tools/update-file.sh $SSHH_ADD_LOCK_TS_FILE --var cmatrixLockFileCreated $cTime
      fi
    fi
    if [[ ! -z $timeout && $timeout != 0 ]]; then
      [[ $timeout == -1 ]] && timeout=$((3 * 60 * 60))
      [[ $timeout -lt 5 ]] && timeout=5
      reset
      run-for-some-time.sh --cmd "$cmatrix_cmd -C ${colors[$c1]}; reset" --watchdog-cmd 'cmatrix' --wait $((timeout-2)):2
      if [[ $? != 255 ]]; then
        read -s -n 10000 -t 0.5 tmp
        [[ $SSHH_ADD_LOCK_TS_FILE != '-' ]] && $ENV_SCRIPTS/file-tools/update-file.sh $SSHH_ADD_LOCK_TS_FILE --var cmatrixLockTime "$((cmatrixLockTime + $EPOCHSECONDS - cTime))"
        [[ -n $title ]] && tmux set -g set-titles-string "$title"
        mutex-unlock; mutex-deinit
        return 0
      fi
    fi
    { # {{{
      /usr/bin/expect - <<-EOF
				set timeout -1
				spawn ssh-add -x
				match_max 100000
				expect "Enter lock password: "
				send -- "$::env(SSH_AGENT_LOCK_PWD)\r"
				expect "Again: "
				send -- "$::env(SSH_AGENT_LOCK_PWD)\r"
				expect eof
			EOF
    } >/dev/null 2>&1 # }}}
    # }}}
  else # {{{
    local err= locked=false
    echormf "Locking ssh-agent...\n"
    while true; do
      ssh-add -x 2>/dev/null
      case $? in
      0) locked=true; break;;
      2) echormf 0 "Cannot connect to ssh-agent\n"; break;;
      esac
      echormf 0 "Password mismatch, try again...\n"
    done
  fi # }}}
  while true; do # {{{
    eval $cmatrix_cmd -C ${colors[$c2]}
    reset
    if $locked; then # {{{
      local checkHome=false
      [[ ! -z $SSH_AGENT_LOCK_PWD ]] && checkHome=true
      if [[ $cmatrixLockFileCreated -gt $(date +%s -d "today 0:00") ]]; then
        if $checkHome; then
          progress --mark --msg "Unlocking after $(time2s --to-hms $((EPOCHSECONDS - cTime)))/$(time2s --to-hms $((cmatrixLockTime + $EPOCHSECONDS - cTime)))"
        else
          echormf 0 "Unlocking after $(time2s --to-hms $((EPOCHSECONDS - cTime)))/$(time2s --to-hms $((cmatrixLockTime + $EPOCHSECONDS - cTime)))..."
        fi
      elif $checkHome; then
        progress --mark --msg "Unlocking"
      fi
      while true; do # {{{
        local homeNet=false
        if $checkHome; then # {{{
          net-is-home && homeNet=true
          progress --unmark --err=$homeNet; checkHome=false
        fi # }}}
        if $homeNet; then # {{{
          {
            /usr/bin/expect - <<-EOF
							set timeout -1
							spawn ssh-add -X
							match_max 100000
							expect "Enter lock password: "
							send -- "$::env(SSH_AGENT_LOCK_PWD)\r"
							expect eof
						EOF
          } >/dev/null 2>&1 # }}}
        else # {{{
          run-for-some-time.sh --cmd "ssh-add -X 2>/dev/null" --wait 12:2
        fi # }}}
        local err=$?
        if [[ $err == 255 ]]; then # {{{
          while true; do
            local cNew="$(( ($c2 + 1 + $RANDOM % (${#colors[*]} - 1)) % ${#colors[*]} ))"
            [[ $cNew != $c1 ]] && c2=$cNew && break
          done
          continue 2
        fi # }}}
        [[ $err == 0 ]] && break 2
        echormf 0 "Incorrent password, try again...\n"
      done # }}}
    fi # }}}
  done # }}}
  [[ -n $title ]] && tmux set -g set-titles-string "$title"
  [[ $SSHH_ADD_LOCK_TS_FILE != '-' ]] && $ENV_SCRIPTS/file-tools/update-file.sh $SSHH_ADD_LOCK_TS_FILE --var cmatrixLockTime "$((cmatrixLockTime + $EPOCHSECONDS - cTime))"
  mutex-unlock
  mutex-deinit
  if [[ ! -z $SSHH_ADD_LOCK_POST ]]; then
    if [[ -x ${SSHH_ADD_LOCK_POST/ *} ]]; then
      $SSHH_ADD_LOCK_POST
    else
      eval $SSHH_ADD_LOCK_POST
    fi
  fi
  return 0
} # }}}
_sshh-add() { # @@ # {{{
  local key_location="$HOME/.ssh/keys"
  local key= keys= k= params=
  keyName() { # {{{
    local key=$1
    key=${key%.pub}; key=${key#id_}
    echo "$key"
  } # }}}
  if [[ $1 == '@@' ]]; then # {{{
    local ret=
    keys="$(ls *.pub 2>/dev/null)"
    if [[ ! -z $keys ]]; then
      for key in $keys; do
        key=${key/.pub}
        key=${key#id_}
        ret+=" $key"
      done
    fi
    if [[ -e $key_location ]]; then
      ret+=" $(cd $key_location; find -L . -name '*.pub' | cut -c3- | while read key; do echo "$(keyName $key)"; done)"
    fi
    if [[ -e $HOME/.ssh ]]; then
      shopt -s nullglob
      for kDir in $HOME/.ssh/keys-*; do
        [[ -d $kDir || -h $kDir ]] || continue
        ret+=" $(cd $kDir; find -L . -name '*.pub' | cut -c3- | while read key; do echo "${kDir##*/keys-}/$(keyName $key)"; done)"
      done
    fi
    ret+=" $(ssh-add --help 2>&1 | grep  ^"  -" | cut -d' ' -f3)"
    if [[ $cur == -* ]]; then
      ret+=" --lock -v --keys --tmux-lock --tmux-unlock"
      ret+=" -l -d -D"
    fi
    echo $ret
    return 0
  fi # }}}
  local params=$@
  if [[ -z $params ]]; then # {{{
    keys="$(find -L $key_location -maxdepth 1 -not -name '*_pwd*' -name '*.pub')"
    if [[ ! -z $keys ]]; then
      params="--keys "
      for key in $keys; do
        key=${key/.pub}
        [[ -e $key ]] && params+="${key/$key_location\/} "
      done
    else
      params="--keys $SSH_KEYS"
    fi
  fi # }}}
  set -- $params
  params="$SSHH_ADD_PARAMS"
  key= keys=
  import-module echor
  while [[ ! -z $1 ]]; do # {{{
    case $1 in # {{{
    --tmux-lock) # {{{
      tmux-lock-toggle --lock
      return 0;; # }}}
    --tmux-unlock) # {{{
      tmux-lock-toggle --unlock
      return 0;; # }}}
    --lock) # {{{
      shift
      _screen_lock "$@"
      return 0;; # }}}
    -l | -d | -D) ssh-add $1; return;;
    -v) echormf +;;
    --keys) shift; break;;
    -*) params+=" $1";;
    *) break;;
    esac # }}}
    shift
  done # }}}
  declare -A no_dups
  for k in $@; do no_dups[$k]=1; done; shift $#
  for k in ${!no_dups[@]}; do # {{{
    [[ $k == -* ]] && continue
    key=$k
    local path=
    while true; do
      [[ -f $key && -f $key.pub ]] && break
      [[ $key =~ (.*/)?(.*) ]]
      path="${BASH_REMATCH[1]}"
      key="${BASH_REMATCH[2]}"
      [[ $key != "id_"* ]] && key="id_$key"
      [[ -f $key_location/$path$key && -f $key_location/$path$key.pub ]] && key="$key_location/$path$key" && break
      [[ -f $HOME/.ssh/keys-$path$key && -f $HOME/.ssh/keys-$path$key.pub ]] && key="$HOME/.ssh/keys-$path$key" && break
      [[ -z $path ]] || break
      key="$(find $key_location -name $key.pub)"
      [[ -z $key ]] && break
      [[ "$(echo  "$key" | wc -l)" -eq 1 ]] || eval $(die -c2 "multiple keys for [$k]")
      key=${key%.pub}
      break
    done
    [[ -e $key ]] || eval $(die -c "key file [$k] not found")
    [[ " $keys " != *" $key "* ]] && keys+=" $key"
  done # }}}
  local fSshAsk=$TMP_MEM_PATH/ssh-ask.sh pList=
  pList="$(keep-pass --list-all)"
  local kList="$(ssh-add -l | awk '{print $2}')"
  for k in $keys; do # {{{
    [[ $k == -* ]] && continue
    [[ $kList == *"$(ssh-keygen -lf $k | awk '{print $2}')"* ]] && continue
    local kDir=
    [[ $k == */* ]] && kDir=${k%/*} && kDir=${kDir##*/}
    local kName=${k##*/}
    local paramK=SSHH_ADD_PARAMS_${kDir^^}_${kName^^}
    paramK=${paramK//-/_}
    local cmd="ssh-add $params ${!paramK} $k"
    if [[ ! -z $pList ]]; then
      local kpName=$kName
      echo "$pList" | grep -q "^$kpName$" || kpName=$kDir/$kName
      echo "$pList" | grep -q "^$kpName$" || kpName=
      if [[ ! -z $kpName ]] && keep-pass --get --key $kpName --no-intr >/dev/null 2>&1; then
        if [[ ! -e $fSshAsk ]]; then
          cat >$fSshAsk <<-'EOF'
						#!/usr/bin/env bash
						read k
						keep-pass --get --key $k --no-intr
					EOF
          chmod +x $fSshAsk
        fi
        cmd="SSH_ASKPASS_REQUIRE=force SSH_ASKPASS=$fSshAsk $cmd <<<$kpName"
      fi
    fi
    echormf -f? && echorv -M 1 cmd
    local out="$(eval $cmd 2>&1)"
    echormf 2 "$out"
  done # }}}
  [[ -e $fSshAsk ]] && rm -f $fSshAsk
  return 0
} # }}}
_sshh-add "$@"

