getIssueFile() { # {{{
  [[ -e "$path_issue/${issue}-data.txt" ]] && echo "$path_issue/${issue}-data.txt" && return 0
  [[ -e "$path_issue/.${issue}-data.txt" ]] && echo "$path_issue/.${issue}-data.txt" && return 0
  eval $(die "Cannot find issue file for issue '$issue'/'$path_issue'")
}
export -f getIssueFile
