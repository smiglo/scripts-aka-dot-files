if is-installed -w grc >/dev/null 2>&1; then # {{{
  grc_prgs=''
  grc_prgs+="traceroute ::google.pl\n"
  grc_prgs+="mtr ::google.pl @@case \\\$1 in 8) arg='8.8.8.8';; esac;\n"
  grc_prgs+="ping ::-c:5:8.8.8.8 @@case \\\$1 in 8) arg='8.8.8.8';; .*) arg=\\\$(get-ip \\\$1);; esac;\n"
  grc_prgs_cols=''
  grc_prgs_cols+="mount\n"
  grcFile="/etc/profile.d/grc.sh"
  $IS_MAC && grcFile="$(brew --prefix)/etc/grc.sh"
  if [[ -e $grcFile ]] && ${GRC_USE_DEFAULTS:-true}; then
    declare -A aliases_orig=()
    aliases_exclude="head\|tail\|ls"
    $IS_ARCH && aliases_exclude+="\|ip"
    for aliases_i in ${!BASH_ALIASES[@]}; do
      aliases_orig[$aliases_i]="${BASH_ALIASES[$aliases_i]#colourify }"
      [[ $aliases_i == "l." || $aliases_i =~ ^\.[0-9]+$ ]] && continue
      [[ ${BASH_ALIASES[$aliases_i]} =~ "colourify" ]] && continue
      aliases_exclude+="\|$aliases_i"
    done
    GRC="$(which grc)" # as we don't source grc directly, we have to set GRC
    source <(sed -n -e '/^\s*alias /p' $grcFile | sed '/\('"$aliases_exclude"'\)=/d')
    alias diffc='colourify diff'
    alias df="colourify ${aliases_orig["df"]:-${BASH_ALIASES["df"]}}"
    alias du="colourify ${aliases_orig["du"]:-${BASH_ALIASES["du"]}}"
    alias diff="colourify ${aliases_orig["diff"]:-${BASH_ALIASES["diff"]}}"
    alias diff-sbs="colourify ${aliases_orig["diff-sbs"]:-${BASH_ALIASES["diff-sbs"]}}"
    alias env="colourify env"
    is-installed -w lsof && alias lsof='colourify lsof'
    unset aliases_exclude aliases_orig aliases_i
  else
    grc_prgs+="configure\ngcc\nnetstat\nwdiff\nlast\nps\ndig\nip\nifconfig\n"
    alias colourify="$(which grc) -es"
  fi
  unset grcFile
  if type column >/dev/null 2>&1; then
    for grc_cmd in $(echo -e "$grc_prgs_cols"); do
      is-installed -w $grc_cmd || continue
      alias ${grc_cmd/:*}="__util_grc_f() { [[ -z \$1 && -t 1 ]] && { command ${grc_cmd//:/ } | column -t | grcat conf.${grc_cmd%%:*}; } || command ${grc_i//:/ } "\$@"; }; __util_grc_f"
    done
  else
    grc_prgs+="$grc_prgs_cols"
  fi
  $IS_MAC && grc_prgs="${grc_prgs/mtr/sudo-mtr}"
  while read grc_cmd grc_i; do
    [[ ! -z $grc_cmd ]] || continue
    is-installed -w $grc_cmd || continue
    grc_sudo= grc_def= grc_code=":" grc_params=
    [[ $grc_cmd == sudo-* ]] && grc_cmd="${grc_cmd#sudo-}" && grc_sudo="sudo"
    while [[ ! -z $grc_i ]]; do
      grc_ii="${grc_i%% *}"
      case $grc_ii in
      ::*) grc_def="${grc_ii#::}"; grc_def="${grc_def//:/ }";;
      @@*) grc_code="${grc_i#@@}"; break;;
      *)   grc_params+="$grc_ii ";;
      esac
      grc_i="${grc_i#$grc_ii}" && grc_i="${grc_i# }"
    done
    alias $grc_cmd="__util_grc_f() { arg=\"\$@\"; ${grc_code%;}; $grc_sudo colourify $grc_cmd \${arg:-$grc_def}; }; __util_grc_f"
  done <<<"$(echo -e "$grc_prgs")"
  unset grc_prgs grc_prgs_cols grc_cmd grc_i grc_ii grc_sudo grc_def grc_code grc_params
fi # }}}

