smart_alias() { # {{{
  local cmd= store=
  while [[ ! -z $1 ]]; do # {{{
    case $1 in
    --title) set-title "$2"; shift;;
    --cmd)   cmd="$2"; shift;;
    --store) store="$2"; shift;;
    --)      shift; break;;
    *)       break;;
    esac
    shift
  done # }}}
  [[ -n $cmd ]] || eval $(die "Command is missing")
  if [[ ! -z $store ]]; then # {{{
    if [[ -z $1 ]]; then
      [[ ! -z $store ]] && set -- ${!store}
    else
      export $store="$@"
    fi
  fi # }}}
  eval "$cmd"
}
