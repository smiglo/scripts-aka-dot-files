# Runtime file # {{{
if [[ -e $RUNTIME_PATH/runtime-common.bash ]]; then
  source $RUNTIME_PATH/runtime-common.bash
elif $IS_DOCKER && [[ -e ${RUNTIME_PATH/$HOME/\/home\/host}/runtime-common.bash ]]; then
  source ${RUNTIME_PATH/$HOME/\/home\/host}/runtime-common.bash
fi
[[ ! -e $RUNTIME_PATH/runtime.bash ]] && touch $RUNTIME_PATH/runtime.bash
for profi in $($BASH_PATH/env-ext.sh get-plugins runtime.bash); do
  source $profi
done
if $IS_VIRTUAL_OS && [[ -e $BASH_PATH/runtime-virtos.bash ]]; then # {{{
  source $BASH_PATH/runtime-virtos.bash
fi # }}}
for profi in $($BASH_PATH/env-ext.sh get-plugins runtime); do
  source $profi
done
