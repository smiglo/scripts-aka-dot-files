  if [[ ! -e $HOME/.bin/tmux-local-bin && -e $HOME/.config/tmux-local/.use-local && -e $HOME/.config/tmux-local/local/bin/tmux ]]; then
    ln -sf $HOME/.config/tmux-local/local/bin $HOME/.bin/tmux-local-bin
  fi
  if [[ -e $HOME/.bin/tmux-local-bin ]]; then
    export PATH="$HOME/.bin/tmux-local-bin:$PATH"
    tmux -V 2>&1 | command grep -q "no version information available" && export LD_LIBRARY_PATH="$HOME/.config/tmux-local/local/lib:$LD_LIBRARY_PATH"
    [[ -e $HOME/.config/tmux-local/local/share/terminfo ]] && export TERMINFO=$HOME/.config/tmux-local/local/share/terminfo
    [[ -e $HOME/.config/tmux-local/local/share/man/man1/tmux.1 ]] && export MANPATH="$HOME/.config/tmux-local/local/share/man:$MANPATH"
  fi
fi # }}}
export _RR_TRACE_DIR="./.rr"
export RLWRAP_HOME="$APPS_CFG_PATH/rlwrap"
[[ -e $RLWRAP_HOME ]] || mkdir -p $RLWRAP_HOME &>/dev/null
export RLWRAP_OPTS="-A -b '' -e '' -D 2"
export RSYNC_DEFAULT_PARAMS_VERBOSE="-ahtpH --no-whole-file --modify-window=2 --progress"
export RSYNC_DEFAULT_PARAMS="$RSYNC_DEFAULT_PARAMS_VERBOSE --no-v --no-progress --info=progress2"
export RSYNC_DEFAULT_PARAMS_FAT="--update --times -rlptgoD --size-only --no-o --no-g --no-p -O"
# # }}}
# Env - not grouped # {{{
export COLUMNS LINES
export DATE_FMT="%Y%m%d-%H%M%S"
export TIME_FMT="%H:%M:%S"
export DATE2_FMT="%Y%m%d"
if [[ -z $COMPLETION_BASH_PATH ]]; then # {{{
  f="/usr/share/bash-completion"
  if $IS_MAC; then
    f="/usr/local/share/bash-completion"
    [[ ! -e $f/bash_completion && -e /usr/local/etc/bash_completion ]] && ln -sf /usr/local/etc/bash_completion $f/
  fi
  [[ -e $f/bash_completion ]] && export COMPLETION_BASH_PATH="$f"
  unset f
fi # }}}
[[ -e $BIN_PATH/ticket-tool ]] && export TICKET_TOOL_PATH=$BIN_PATH/ticket-tool
export REMINDER_PATH="$APPS_CFG_PATH/reminders"
[[ -e "$SCRIPT_PATH/bin/oth/tmux-sb-worker.sh" ]] && export TMUX_SB_WORKER="$SCRIPT_PATH/bin/oth/tmux-sb-worker.sh"
if ${REMINDER_MONITOR_AUTOSTART:-true} && [[ -z $REMINDER_MONITOR_CMD && -e "$SCRIPT_PATH/bin/reminder.sh" ]]; then
  export REMINDER_MONITOR_CMD="$SCRIPT_PATH/bin/reminder.sh"
fi
export TMUX_SB_INTERVAL=15
[[ -e $TOOLS_PATH/pwndbg/gdbinit.py ]] && export GDB_PWNDBG_INIT="$TOOLS_PATH/pwndbg/gdbinit.py"
export LC_COLLATE=C
export GOBIN="$HOME/.local/bin"
[[ -z $NODE_USE_NVM && -e $HOME/.nvm ]] && export NODE_USE_NVM=true
if [[ -z $PRJ_PATH ]]; then
  if [[ -e $HOME/w ]]; then
    export PRJ_PATH="$HOME/w"
  else
    export PRJ_PATH="$HOME/projects"
    mkdir -p "$PRJ_PATH"
  fi
fi
[[ -z $WORKSPACE ]] && export WORKSPACE="$PRJ_PATH"
export W=$WORKSPACE
# vim - cpp # {{{
