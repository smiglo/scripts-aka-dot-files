# PATH # {{{
export PATH="$HOME/.cargo/bin:$PATH"
export PATH="$HOME/.local/bin:$PATH"
[[ -e $TOOLS_PATH/.runtime.bash ]] && source $TOOLS_PATH/.runtime.bash
if $IS_MAC && is-installed -w brew; then # {{{
  pathFile="$BASHRC_RUNTIME_PATH/brew.paths" prefix="$(brew --prefix)"
  if [[ ! -e $pathFile ]]; then
    brewPaths="$( \
      find $prefix/Cellar -type d -path '*/libexec/gnubin' \
      | grep -v "${BREW_LIBEXEC_EXCLUDE:-@@@}" \
      | tr '\n' ':')"
    ccachePath=$(ls -d $prefix/Cellar/ccache/*/libexec 2>/dev/null)
    [[ -n $ccachePath ]] && brewPaths+="$ccachePath:"
    echo "${brewPaths%:}" >>$pathFile
    unset brewPaths prefix ccachePath
  fi
  [[ -s $pathFile ]] && PATH="$(< $pathFile):$PATH"
  unset pathFile
fi # }}}
