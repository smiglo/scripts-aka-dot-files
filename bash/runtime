    if [[ ! -z $(shopt -s nullglob; echo $ENV_PATH/vim/git-plugins/YouCompleteMe/third_party/ycmd/ycm_core.*.so) ]]; then
      export VIM_YCM_PATH="$ENV_PATH/vim/git-plugins/YouCompleteMe"
      export VIM_CLANG_PATH='-'
    fi
  fi
fi
if [[ -z $VIM_CLANG_PATH ]]; then
