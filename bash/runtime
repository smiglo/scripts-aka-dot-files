#!/usr/bin/env bash
# vim: fdl=0

# Check for MC # {{{
if false; then
  export IS_IN_MC=$( [[ $PPID != 0 && "$(command ps -o comm= -p $PPID)" == "mc" ]] && echo 'true' || echo 'false')
  if $IS_IN_MC; then
    export PROMPT_COMMAND=
    export PS1='\$ '
    export RCSTUFF_RUNTIME_INSTALLED=true
    return
  fi
fi # }}}
# Is installed # {{{
${RCSTUFF_RUNTIME_INSTALLED:-false} && [[ $1 != '--force' ]] && return 0
[[ $1 == '--force' ]] && shift
export RCSTUFF_RUNTIME_INSTALLED=true
# }}}
# Unicode extra chars # {{{
if [[ -z ${UNICODE_EXTRA_CHARS[bell]} ]] || $RCSTUFF_FORCE; then
  source $BASH_PATH/unicode
  export UNICODE_EXTRA_CHARS_FILE="$BASHRC_RUNTIME_PATH/unicode-extra.conf"
fi
export TMUX_ICONS=
export TMUX_ICONS+=" exclamation:${UNICODE_EXTRA_CHARS[exclamation]}"
export TMUX_ICONS+=" smart:${UNICODE_EXTRA_CHARS[smart]}"
export TMUX_ICONS+=" ssh:${UNICODE_EXTRA_CHARS[ssh]}"
export TMUX_ICONS+=" zoom:${UNICODE_EXTRA_CHARS[zoom]}"
export TMUX_ICONS+=" localhost:${UNICODE_EXTRA_CHARS[localhost]}"
export TMUX_ICONS+=" docker:${UNICODE_EXTRA_CHARS[docker]}"
${INPUTRC_MODE_CHAR_USE:-true} && export INPUTRC_MODE_CHAR="☯ "
# }}}
# Static completions # {{{
COMPLETION_STATIC[npm]="run test install ci i audit ls exec"
COMPLETION_STATIC[npm:audit]="fix"
COMPLETION_STATIC[npm:audit:fix]="--force"
COMPLETION_STATIC[npx:semantic-release]="--dry-run" # }}}
# Personalities # {{{
[[ -e $BASH_PATH/personalities/personalities ]] && source $BASH_PATH/personalities/personalities
[[ -e $RUNTIME_PATH/personalities ]] && source $RUNTIME_PATH/personalities
# }}}
# Path # {{{
export PATH=@END@:$PATH
export PATH=$SCRIPT_PATH/bin:$PATH
export PATH=$SCRIPT_PATH/git/bin:$PATH
export PATH=$APPS_CFG_PATH/bin:$RUNTIME_PATH/bin:$BIN_PATH:$BIN_PATH/vims:$PATH
# }}}
# FZF Runtime # {{{
fzfPath=$FZF_PATH
if [[ -z $FZF_INSTALLED || -z $VIM_FZF_RUNTIME_PATH ]]; then
  export FZF_INSTALLED=false
  if [[ -z $fzfPath ]]; then # {{{
    if [[ -e $TOOLS_PATH/fzf/bin/fzf ]]; then
      fzfPath="$TOOLS_PATH/fzf/bin"
    elif [[ -e /usr/bin/fzf ]]; then
      fzfPath="/usr/bin"
    elif [[ -e /usr/local/bin/fzf ]]; then
      fzfPath="/usr/local/bin"
    elif [[ -e $SCRIPT_PATH/inits/fzf/bin/fzf ]]; then
      fzfPath="$SCRIPT_PATH/inits/fzf/bin"
    fi
  fi # }}}
  if [[ ! -z $fzfPath  ]]; then
    FZF_INSTALLED=true
    [[ :$PATH: == *:$fzfPath:* ]] || PATH=$fzfPath:$PATH
  elif is-installed fzf; then
    FZF_INSTALLED=true
  fi
  if $FZF_INSTALLED; then
    if which fzf >/dev/null 2>&1; then
      export VIM_FZF_RUNTIME_PATH="$(readlink -f $(which fzf))"
      export VIM_FZF_RUNTIME_PATH="${VIM_FZF_RUNTIME_PATH%/*/*}"
    else
      FZF_INSTALLED=false
      export VIM_FZF_RUNTIME_PATH="/not-exist"
    fi
  fi
fi
unset fzfPath # }}}
# tools # {{{
# phistory # {{{
[[ -z $BASH_PHISTORY_FILE ]] && export BASH_PHISTORY_FILE="$HOME/.bash_phistory"
if $BASHRC_FULL_START && [[ -e "$BASH_PHISTORY_FILE" ]]; then
  sed -i '/ | [0-9]\{8\}-[0-9]\{6\} | \.\.\.$/d' "$BASH_PHISTORY_FILE" 2>/dev/null
  sed -i '/^[^|]/d' "$BASH_PHISTORY_FILE" 2>/dev/null
fi
[[ -z $BASH_PHISTORY_SUM_CMD ]] && export BASH_PHISTORY_SUM_CMD="sha256sum | cut -d' ' -f1 |  xxd -r -p | base64" # }}}
export CHTSH_QUERY_OPTIONS="style=paraiso-light"
# CMake # {{{
if [[ -z $CMAKE_BUILD_PARALLEL_LEVEL ]] && is-installed nproc; then
  export CMAKE_BUILD_PARALLEL_LEVEL="$(nproc)"
fi
if is-installed ccache; then
  export CMAKE_ARGS+=" -DCMAKE_C_COMPILER_LAUNCHER=ccache"
  export CMAKE_ARGS+=" -DCMAKE_CXX_COMPILER_LAUNCHER=ccache"
fi
# export MAKEFILE_COMMON="$SCRIPT_PATH/inits/Makefile"
# # }}}
# ack # {{{
export ACK_OPTIONS="-k --smart-case --color-filename=cyan --color-lineno=green --color-match=yellow"
export ACK_PAGER="less"
export ACK_PAGER_COLOR="less" # }}}
export AG_OPTIONS="--color-path=38;5;6 --color-line-number=38;5;10 --color-match=38;5;214"
# AIder # {{{
if false && is-installed -w aider; then
  export AIDER_DARK_MODE=true
  export AIDER_CODE_THEME="solarized-dark"
  export AIDER_MODEL="gemini/gemini-2.0-flash"
  export AIDER_SHOW_DIFFS=true
  export AIDER_AUTO_COMMITS=false
  export AIDER_VIM=true
  export AIDER_CHAT_LANGUAGE="English"
  export AIDER_EDITOR="vim --fast -cl"
fi # }}}
# Bat # {{{
if [[ -z $BAT_INSTALLED ]]; then
  export BAT_INSTALLED=false
  if is-installed -w bat >/dev/null 2>&1; then
    BAT_INSTALLED=true
    export BAT_PRG="bat"
  elif is-installed -w batcat >/dev/null 2>&1; then
    BAT_INSTALLED=true
    export BAT_PRG="batcat"
  fi
  if $BAT_INSTALLED; then
    export BAT_THEM2="Solarized (dark)"
    export BAT_THEME="TwoDark"
    help() {
      "$@" --help 2>&1 | $BAT_PRG -p -l help --theme "$BAT_THEM2"
    }
  else
    help() {
      "$@" --help
    }
  fi
fi # }}}
# FZF # {{{
if $FZF_INSTALLED && ( [[ -z $FZF_DEFAULT_COMMAND ]] || $RCSTUFF_FORCE ); then
  export FZF_DEFAULT_COMMAND="fzf-find"
  export FZF_ALT_C_COMMAND="fzf-find -d"
  fzf_exe="$ENV_SCRIPTS/fzf-tools/fzf-exe.sh" # has to be in this form for vim fzf-plugin
  export FZF_DEFAULT_OPTS="$(< $SCRIPT_PATH/dot-files/fzf.opts)"
  export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
  export FZF_CTRL_T_OPTS="--preview '$fzf_exe -c prev --prev 20 -f {1}'"
  export FZF_ALT_C_OPTS="-e -x --layout=reverse --prompt='> '"
  declare -A +x fzfUsageA=([ack-ag]=true [mg]=true [grep]=false [out2file]=true [last-grep]=false [phist]=true [cd]=true)
  export FZF_USAGE="$(declare -p fzfUsageA)"
  unset fzf_exe fdfindCmd fzfUsageA
elif ! $FZF_INSTALLED; then
