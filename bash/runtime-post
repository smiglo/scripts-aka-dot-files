#!/usr/bin/env bash
# vim: fdl=0

# Is installed # {{{
${RCSTUFF_RUNTIME_POST_INSTALLED:-false} && [[ $1 != '--force' ]] && return 0
[[ $1 == '--force' ]] && shift
export RCSTUFF_RUNTIME_POST_INSTALLED=true
# }}}
# Runtime file # {{{
RUNTIME_POST_FILE=$RUNTIME_PATH/runtime-post.bash
[[ -e $RUNTIME_POST_FILE ]] && source $RUNTIME_POST_FILE
for profi in $BASH_PROFILES; do
  [[ -e $RUNTIME_POST_FILE.$profi ]] && source $RUNTIME_POST_FILE.$profi
done
unset RUNTIME_POST_FILE
# }}}
# TMUX_STATUS_RIGHT_EXTRA # {{{
if [[ -z $TMUX_STATUS_RIGHT_EXTRA_SORTED ]]; then
  TMUX_STATUS_RIGHT_EXTRA_SORTED=
  while read l; do
    l=$(echo ${l#*:})
    [[ -z $l ]] && continue
    export TMUX_STATUS_RIGHT_EXTRA_SORTED+="$l "
  done < <(echo -e "$TMUX_STATUS_RIGHT_EXTRA" | tr ' ' '\n' | command grep -v '^#' | sort -ut ':' -k2,2 | sort -nt ':' -k1,1)
  unset l TMUX_STATUS_RIGHT_EXTRA
fi # }}}
if ! is-installed --no-cache -t kp-pp; then # {{{
  source "$SCRIPT_PATH/bash/inits/keep-pass/keep-pass-env.sh"
fi # }}}
# Source profiles' runtimes # {{{
for profi in $BASH_PROFILES_FULL; do
  [[ -e $profi/runtime-post ]] && source $profi/runtime-post
done # }}}
# Remote changes # {{{
src_dir="$SHARED_BASH_PATH/to-apply"
if ${REMOTE_CHANGES_APPLY:-false} && [[ ! -z $SHARED_BASH_PATH && $UID != 0 ]]; then
  now="${EPOCHSECONDS:-$(epochSeconds)}" rmt_chngs_file="$MEM_KEEP/remote.changes"
  if [[ -z $REMOTE_CHANGES_LAST || $(($REMOTE_CHANGES_LAST + 12*60*60)) -lt $now ]]; then # {{{
    REMOTE_CHANGES_LAST=0
    [[ -e "$rmt_chngs_file" ]] && source "$rmt_chngs_file"
  fi # }}}
  if [[ $(($REMOTE_CHANGES_LAST + 12*60*60)) -lt $now && -d $src_dir ]]; then
    export REMOTE_CHANGES_LAST="$now"
    echo "export REMOTE_CHANGES_LAST=\"$REMOTE_CHANGES_LAST\"" > $rmt_chngs_file
    i= sum= h_sum= file= p= found=
    for i in $src_dir/*; do # {{{
      file="${i##*/}"
      # To apply or not to apply # {{{
      [[ -d $i ]] && continue
      [[ $i != *.sh && $i != *.enc ]] && continue
      [[ $i == *.sh && ! -x $i ]] && continue
      [[ $i == *.sh ]] && ! ${REMOTE_CHANGES_ALLOW_PLAIN:-true} && continue
      [[ $i == *.enc && -z $REMOTE_CHANGES_PWD && -z $REMOTE_CHANGES_KEY ]] && continue
      if [[ $file != all* ]]; then # {{{
        found=false
        for p in $BASH_PROFILES; do
          [[ $file == ${p}* ]] && found=true && break
        done
        ! $found && continue
      fi # }}} # }}}
      sum="$(shasum $i | cut -d\  -f1)"
      h_sum="$(echo -n ${HOSTNAME%%.*} | shasum | cut -d\  -f1)"
      [[ -e "$src_dir/.applied" ]] && command grep -q "^$h_sum $sum" "$src_dir/.applied" && continue
      echo "Applying remote changes [$file]..." >/dev/stderr
      if [[ $file == *.enc ]]; then # {{{
        j="$TMP_MEM_PATH/${file%.enc}"
        if [[ ! -z $REMOTE_CHANGES_KEY ]]; then
          p="--key '$REMOTE_CHANGES_KEY'"
        elif [[ ! -z $REMOTE_CHANGES_PWD ]]; then
          p="--pass '$($PROFILES_PATH/home/bin/oth/runtime-pwd.sh -q "$REMOTE_CHANGES_PWD")'"
        else
          echo "Missing passphrase for [$file]"
          continue
        fi
        if ! eval encryptor $p "$i" "$j"; then
          echo "Cannot decrypt [$file]"
          continue
        fi
        command chmod +x "$j"
        i="$j"
        unset j
      fi # }}}
      $i && echo "$h_sum $sum $file $(command date +'%Y%m%d')" >>"$src_dir/.applied"
      [[ $file == *.enc ]] && rm -f "$i"
    done # }}}
    unset i sum h_sum file p found
  fi
  unset now rmt_chngs_file
fi
unset REMOTE_CHANGES_APPLY REMOTE_CHANGES_ALLOW_PLAIN REMOTE_CHANGES_PWD REMOTE_CHANGES_KEY src_dir
# }}}
# Check personalities # {{{
[[ -z $PERS_USERS ]] && echo "Personalities not found!!!" >/dev/stderr && sleep 2
# }}}
# nvm # {{{
if [[ -e $HOME/.nvm ]] && ${NODE_USE_NVM:-false}; then
  export NVM_DIR="$HOME/.nvm"
  [[ -s $NVM_DIR/nvm.sh ]] && source $NVM_DIR/nvm.sh
  [[ -s $NVM_DIR/bash_completion ]] && source $NVM_DIR/bash_completion
fi # }}}
# Unicode extra chars # {{{
if [[ ! -z "$UNICODE_EXTRA_CHARS_FILE" && ! -e "$UNICODE_EXTRA_CHARS_FILE" ]]; then
  touch "$UNICODE_EXTRA_CHARS_FILE"
  {
    echo "declare -Ag UNICODE_EXTRA_CHARS"
    for i in $(echo ${!UNICODE_EXTRA_CHARS[*]} | tr ' ' '\n' | sort); do
      echo "UNICODE_EXTRA_CHARS[$i]=\"${UNICODE_EXTRA_CHARS[$i]}\""
    done
    echo
  } >"$UNICODE_EXTRA_CHARS_FILE"
  unset i
fi # }}}
# fzf override # {{{
if $FZF_INSTALLED && [[ -n $PS1 ]]; then # {{{
  eval "$(fzf --bash)"
  __fzf_handler_git() { # {{{
    mode=$1; shift
    case $mode in
    init) # {{{
      p="$PWD"; origPath="$PWD"
      prompt="> "
      expectList="";; # }}}
    loop) # {{{
      ;; # }}}
    expect) # {{{
      local key=$1
      case $key in
      esac;; # }}}
    result) # {{{
      cat - | while read -r item; do
        [[ "$item" =~ .*\|([0-9a-f]{5,})\|.* ]] || continue
        printf "%s\n" "${BASH_REMATCH[1]}"
      done;; # }}}
    preview) # {{{
      local line="$1"
      [[ "$line" =~ .*\|([0-9a-f]{5,})\|.* ]] || return
      local sha=${BASH_REMATCH[1]}
      git log --pretty=fuller --date=local -1 "$sha"
      echo; echo '    ----'
      git diff $sha~..$sha --name-status | sed -e 's/^/    /'
      echo '    ----'; echo
      git diff -w $sha~..$sha \
      | if which colordiff >/dev/null 2>&1; then colordiff -u; else cat -; fi;; # }}}
    esac
  } # }}}
  __fzf_handler_fs() { # {{{
    local mode=$1; shift
    local key_upper="ctrl-u" key_home="ctrl-h" key_into="ctrl-e" key_orig="ctrl-o"
    case $mode in
    init) # {{{
      p="$PWD"; origPath="$PWD"
      expectList="--expect $key_upper --expect $key_home --expect $key_into --expect $key_orig";; # }}}
    loop) # {{{
      command cd "$p"
      prompt="> "
      [[ $PWD != $origPath ]] && prompt="${PWD/$HOME/\~}> ";; # }}}
    expect) # {{{
      local key=$1
      case $key in
      $key_upper) p="$(cd ..; pwd)";;
      $key_home)  p="$HOME";;
      $key_orig)  p="$origPath";;
      $key_into)
        p="$(echo "$list" | sed -n '2p')"
        $dirMode || p="$(dirname "$p")"
        p="$PWD/$p";;
      esac;; # }}}
    result) # {{{
      cat - | while read -r item; do
        printf '%q\n' "$PWD/$item"
      done \
      | sed -e 's|'"$PWD/"'||';; # }}}
    preview) # {{{
      local f="$1"
      [[ -e $f || ( -h $f && -f $(readlink -f $f) ) ]] || return
      cat.sh -p $f;; # }}}
    esac
  } # }}}
  __fzf_select__() { # {{{
    local dirMode=false
    FZF_DEFAULT_COMMAND="${FZF_CTRL_T_COMMAND:-} | sed 's|^\./||'"
    local optsDef="--reverse ${FZF_CTRL_T_OPTS-}" opts="-m --ansi" optsWalker="--walker=file,dir,follow,hidden --scheme=path"
    local handler="__fzf_handler_fs"
    while [[ ! -z $1 ]]; do # {{{
      case $1 in
      --cmd) # {{{
        FZF_DEFAULT_COMMAND="$2"; shift
        handler="";; # }}}
      --dir) # {{{
        dirMode=true
        optsWalker="--walker=dir,follow,hidden --scheme=path"
        FZF_DEFAULT_COMMAND="${FZF_ALT_C_COMMAND:-} | sed 's|^\./||'"
        optsDef="${FZF_ALT_C_OPTS-}";; # }}}
      --opts-walker) # {{{
        optsWalker="$2"; shift;; # }}}
      --opts) # {{{
        opts="$s"; shift;; # }}}
      --handler) # {{{
        handler="$2"; shift;; # }}}
      *) break;;
      esac; shift
    done # }}}
    FZF_DEFAULT_OPTS=$(__fzf_defaults "$optsWalker" "$optsDef $opts")
    (
      export -f $handler
      expectList= prompt=
      $handler init
      fzfCmd="$(__fzfcmd)"
      while true; do
        $handler loop
        list="$(FZF_DEFAULT_OPTS_FILE='' $fzfCmd "$@" --prompt "$prompt" --preview "$handler preview {}" $expectList)"
        if [[ -n $expectList ]]; then
          local expectKey=$(echo "$list" | sed -n '1p')
          if [[ -n $expectKey ]]; then
            $handler expect $expectKey
            continue
          fi
          list="$(echo "$list" | sed '1d')"
        fi
        [[ -n $list ]] && echo "$list"
        break
      done
    ) | $handler result | tr '\n' ' '
  } # }}}
  __fzf-file-widget() { # {{{
    local selected="$(__fzf_select__ "$@")"
    [[ -n $selected ]] || return 0
    READLINE_LINE="${READLINE_LINE:0:$READLINE_POINT}$selected${READLINE_LINE:$READLINE_POINT}"
    READLINE_POINT=$(( READLINE_POINT + ${#selected} ))
  } # }}}
  __fzf-dir-widget() { # {{{
    local selected="$(__fzf_select__ --dir "$@")"
    [[ -n $selected ]] || return 0
    READLINE_LINE="${READLINE_LINE:0:$READLINE_POINT}$selected${READLINE_LINE:$READLINE_POINT}"
    READLINE_POINT=$(( READLINE_POINT + ${#selected} ))
  } # }}}
  __fzf-cd-widget() { # {{{
    __fzf-dir-widget "$@"
  } # }}}
  __fzf-git-widget() { # {{{
    local selected="$(__fzf_select__ --cmd "git log --graph --oneline --decorate --color --format='%C(240)|%C(172)%h%C(240)|%C(reset)%C(auto)%d %C(dim white)%s%C(reset)' --exclude=refs/remotes/* --exclude=refs/tags/* --decorate-refs-exclude=refs/tags/tmp/sync/* --branches --remotes" --handler "__fzf_handler_git")"
    [[ -n $selected ]] || return 0
    READLINE_LINE="${READLINE_LINE:0:$READLINE_POINT}$selected${READLINE_LINE:$READLINE_POINT}"
    READLINE_POINT=$(( READLINE_POINT + ${#selected} ))
  } # }}}
  __fzf-history() { # {{{
    local rlPoint=$READLINE_POINT
    READLINE_POINT=
    READLINE_LINE="$( history -r; __fzf_history__)"
    READLINE_POINT=$rlP
  } # }}}
  bind -m vi-command -r "\C-r"
  bind -m vi-insert  -r "\C-r"
  bind -m vi-command -x '"\C-w\C-e": "__fzf-git-widget"'
  bind -m vi-insert  -x '"\C-w\C-e": "__fzf-git-widget"'
  bind -m vi-command -x '"\C-w\C-r": "__fzf-history"'
  bind -m vi-insert  -x '"\C-w\C-r": "__fzf-history"'
  bind -m vi-command -x '"\C-t"    : "__fzf-file-widget"'
  bind -m vi-insert  -x '"\C-t"    : "__fzf-file-widget"'
  bind -m vi-insert     '"\ec"     : "\C-gcd\C-m"'
  bind -m vi-command -x '"\ed"     : "__fzf-cd-widget"'
  bind -m vi-insert  -x '"\ed"     : "__fzf-cd-widget"'
fi 2>/dev/null # }}}
# }}}
if ${TMUX_POPUP:-false}; then # {{{
  if ! $TMUX_POPUP_SILENT; then
    echoe -m popup "s=[$s]"
    echoe -m popup "d=[$d]"
  fi
  export BASH_PHISTORY_FILE=
  export TMUX_SESSION=POPUP
  if [[ ! -z $d ]]; then
    set-utils -h "$d" +basic +hist +remember-conf-dir=.remb +note-file=notes.txt
  fi
fi # }}}
if $IS_DOCKER; then # {{{
  if ! $IS_VSCODE && $BASHRC_FULL_START; then # {{{
    $ALIASES_SCRIPTS/docker-tools/clipboard-docker.sh &
    disown $!
  fi # }}}
fi # }}}
if $IS_VSCODE; then # {{{
  set-utils -h "$APPS_CFG_PATH/vscode" +basic +hist +remember-conf-dir=.remb +note-file=notes.txt
fi # }}}
unset -f set-utils

