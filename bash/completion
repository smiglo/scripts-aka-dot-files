#!/usr/bin/env bash
# vim: fdl=0

# Is installed # {{{
if ${RCSTUFF_COMPLETION_INSTALLED:-false}; then
  [[ $1 == '--force' ]] || ${RCSTUFF_FORCE:-false} || return 0
fi
BASHRC_COMPLETION_FULL=true
[[ $1 == '--force' ]] && shift
${RCSTUFF_FORCE:-false} && BASHRC_COMPLETION_FULL=true
export RCSTUFF_COMPLETION_INSTALLED=true
# }}}
if $BASHRC_COMPLETION_FULL; then # {{{
  compl-help() { # {{{
    if [[ $1 == @@ ]]; then # {{{
      echo "$EXPORTED_FUNCTIONS"
      echo "-s --short -l --long @@-f @@-d"
      declare -Fx | cut -d' ' -f3 | command grep -v "^_"
      return 0
    fi # }}}
    local cmd= short=false
    while [[ ! -z $1 ]]; do # {{{
      case $1 in
      -l | --long)  short=false;;
      -s | --short) short=true;;
      *) cmd="$1"; shift $#;;
      esac; shift
    done # }}}
    if [[ -z $cmd && ! -t 0 ]]; then
      cmd="$(<-)"
    elif [[ -e "$cmd" ]]; then
      cmd="$(<"$cmd")"
    elif ! declare -F "$cmd" >/dev/null 2>&1; then
      cmd="$(which "$cmd")"
      cmd="$(<"$cmd")"
    else
      cmd="$(type "$cmd")"
      if [[ $cmd =~ (\$ALIASES_SCRIPTS/[^ ]*) ]]; then
        local f=${BASH_REMATCH[1]}
        f="$(eval echo "$f")"
        cmd="$(<$f)"
      fi
    fi
    local indent="$(echo "$cmd" | command grep '^ *while \[\[ ! -z $1 \]\]; do' | head -n1 | command grep -o "^ *")"
    local parser="$(echo "$cmd" | sed -n '/'"^$indent"'while/,/'"^$indent"'done/p' | command cat -n)"
    local caseS="$(echo "$parser" | command cat | awk '/case/ {print $1}' | head -n1)"
    local caseE="$(echo "$parser" | tac | awk '/esac/ {print $1}' | head -n1)"
    caseS=$((caseS+1)) caseE=$((caseE-1))
    parser="$(echo "$parser" | sed -n "$caseS,$caseE p" | cut -c9-)"
    indent="$(echo "$parser" | head -n1 | command grep -o "^ *")"
    parser="$(echo "$parser" | sed 's/^'"$indent"'//')"
    if $short; then
      echo "$parser" | command grep "^[^ ][^)]*)" | sed 's/).*//' | { if [[ -t 1 ]] && is-installed column; then column -t; else command cat -; fi; }
    else
      echo "$parser" | sed -e '/^;;/d' -e 's/;$//' | hl-bash +c=Search "^[^ ][^)]*)"
    fi
  }
  alias ch='compl-help'
  compl-add compl-help ch # }}}
  _do_vim_completion() { # {{{
    local i=
    for i in {,_}{,g,m,r}{vi,view,vim,vimdiff}; do
      if [[ -e $BIN_PATH/vims/$i ]]; then
        while complete -r $i >/dev/null 2>&1; do :; done
        complete $COMPLETE_DEFAULT_PARAMS -D -F _completion_vim $i
      fi
    done
    complete $COMPLETE_DEFAULT_PARAMS -D -F _completion_vim vim-session
  }
  # }}}
  # Completion for git aliases defined in git-extra-completion.sh # {{{
  for ii in $($SCRIPT_PATH/git/git-extra-completion.sh --list); do
    eval "_git_${ii}() { compl-gen; }"
  done
  for ii in $(cd $SCRIPT_PATH/git/bin; ls *); do
    f=${ii#git-} && f=${f//[-]/_}
    grep -q "@@" $SCRIPT_PATH/git/bin/$ii || continue
    eval "_git_$f() { compl-gen; }"
  done
  # }}}
  # Set generic completion # {{{
  COMPLETION_GENERIC_UTILS_OLD+=" gitst"
  for ii in $COMPLETION_GENERIC_UTILS_OLD; do # {{{
    which $ii >/dev/null 2>&1 && compl-add --old $ii # || echoe -s "Util [$ii] not found"
  done # }}}
  for ii in $COMPLETION_GENERIC_UTILS; do # {{{
    which $ii >/dev/null 2>&1 && compl-add --new $ii # || echoe -s "Util [$ii] not found"
  done # }}}
  for ii in $(echo "$COMPLETION_GENERIC_FUNCTIONS" | tr ' ' '\n' | sort -u | tr '\n' ' '); do # {{{
    if type $ii >/dev/null 2>&1; then
      compl-add --new $ii
    else
      echoe -s "Function [$ii] not found"
    fi
  done # }}}
  for ii in $(echo "$COMPLETION_GENERIC_FUNCTIONS_OLD" | tr ' ' '\n' | sort -u | tr '\n' ' '); do # {{{
    if type $ii >/dev/null 2>&1; then
      compl-add --old $ii
    else
      echoe -s "Function [$ii] not found"
    fi
  done # }}}
  unset COMPLETION_GENERIC_UTILS COMPLETION_GENERIC_FUNCTIONS COMPLETION_GENERIC_UTILSCOMPLETION_GENERIC_FUNCTIONS_OLD
  for ii in $BIN_PATH/*.sh; do # {{{
    case $(readlink -f $ii) in
    $SCRIPT_PATH/* | $RUNTIME_PATH/* | $PRJ_PATH/* | $TOOLS_PATH/*)
      compl-add "${ii##*/}";;
    esac
  done # }}}
  # }}}
  # Hosts # {{{
  if [[ -e $HOME/.ssh/known_hosts ]] && tail -1 $HOME/.ssh/known_hosts | command grep -vq "^|1|"; then
    complete -D -W "$( echo `command cat ~/.ssh/known_hosts | cut -f 1 -d ' ' | sed -e s/,.*//g | uniq | command grep -v "\["`;)" ssh
  fi # }}}
  # Vim # {{{
  _do_vim_completion
  unset _do_vim_completion
  # }}}
  # Oth # {{{
  complete | command grep -q " cdd$" || complete $COMPLETE_DEFAULT_PARAMS -D -W "$(cd_wrapper -- @@ - -i | tr '\n' ' ')" cdd
  declare -F _filedir >/dev/null && eval "$(type -a _filedir | tail -n +2 | sed 's/compopt -o filenames 2>/compopt -o filenames -o noquote 2>/')"
  compl-add --smart ./build.sh
  # }}}
  # tldr # {{{
  if [[ -e $HOME/.local/share/tldr ]]; then
    complete -D -W "$(q=($HOME/.local/share/tldr/*/*); sed 's@\.md @ @g' <<<${q[@]##*/})" tldr
  fi # }}}
  # all from own bins/ # {{{
  add_for_all() { # {{{
    local a_dir=$1 a_file=
    for a_file in $a_dir/*; do
      a_file="$(realpath "$a_file")"
      [[ -f $a_file && -x $a_file ]] || continue
      case $a_file in
      $RUNTIME_PATH/bin/* | $SCRIPT_PATH/*);;
      *) continue
      esac
      compl-add $a_file
    done
  } # }}}
  add_for_all $SCRIPT_PATH/bin
  for pp in $BASH_PROFILES_FULL; do
    add_for_all $pp/bin
  done
  unset pp
  add_for_all $BIN_PATH
  unset -f add_for_all
  # }}}
fi # }}}
# Source additional completions # {{{
if [[ -e $BASH_PATH/completion.d ]]; then
  for ii in $(ls $BASH_PATH/completion.d); do
    [[ -f $BASH_PATH/completion.d/$ii ]] && source $BASH_PATH/completion.d/$ii
  done
fi
if [[ -e $RUNTIME_PATH/completion.d ]]; then
  for ii in $(ls $RUNTIME_PATH/completion.d); do
    [[ -f $RUNTIME_PATH/completion.d/$ii && ( -x $RUNTIME_PATH/completion.d/$ii || $ii == *.sh || $ii == *.bash ) ]] && source $RUNTIME_PATH/completion.d/$ii
  done
fi
# }}}
# Source profile specic completions # {{{
for profi in $BASH_PROFILES_FULL; do
  [[ -e $profi/completion ]] && source $profi/completion
done
unset profi ii
# }}}
source $SCRIPT_PATH/bash/completion.alias
if [[ -e $COMPLETION_BASH_PATH/bash_completion ]]; then # {{{
  source $COMPLETION_BASH_PATH/bash_completion
  if ${BASHRC_GIT_COMPLETION_FIX:-true}; then
    [[ -e "$COMPLETION_BASH_PATH/completions/git" ]] && source "$COMPLETION_BASH_PATH/completions/git"
  fi
fi # }}}
# overrides of commons utils # {{{
complete $COMPLETE_DEFAULT_PARAMS -F _completion_npm npm
complete $COMPLETE_DEFAULT_PARAMS -F _completion_npx npx
compl-add --old cd
# }}}
true
